; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="SuikaGame"
run/main_scene="uid://d2682g4r85urc"
config/features=PackedStringArray("4.6", "GL Compatibility")
run/max_fps=60
boot_splash/show_image=false
config/icon="uid://c414daqfqyq2c"

[audio]

buses/default_bus_layout="uid://cqadrvtgfogr7"

[autoload]

SignalBus="*uid://5wkgn732bie"
AudioManager="*uid://oq71npodsb8n"
YandexManager="*uid://drfnt3xtnwjqk"
GameManager="*uid://j038mbivaa7e"

[debug]

gdscript/warnings/unused_signal=0
shapes/avoidance/3d/obstacles_static_face_pushin_color=Color(0.95281494, 0, 0.5526029, 0.5)
shapes/avoidance/2d/obstacles_static_face_pushin_color=Color(0.95281494, 0, 0.5526029, 0.5)

[display]

window/size/viewport_width=1080
window/size/viewport_height=1920
window/size/window_width_override=400
window/size/window_height_override=700
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/vsync/vsync_mode=0

[editor]

naming/scene_name_casing=1
naming/script_name_casing=1

[editor_plugins]

enabled=PackedStringArray("res://addons/SimpleFormatOnSave/plugin.cfg", "res://addons/minimize_html_build/plugin.cfg")

[file_customization]

folder_colors={
"res://Addons/": "gray",
"res://Assets/": "orange",
"res://Builds/": "gray",
"res://Core/": "pink",
"res://Globals/": "purple",
"res://UI/": "green",
"res://_Builds/": "gray"
}

[global_group]

flowers=""

[input]

drop={
"deadzone": 0.2,
"events": [Object(InputEventMouseButton,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"button_mask":1,"position":Vector2(76, 10),"global_position":Vector2(85, 58),"factor":1.0,"button_index":1,"canceled":false,"pressed":true,"double_click":false,"script":null)
]
}
debug_panel={
"deadzone": 0.2,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":96,"key_label":0,"unicode":96,"location":0,"echo":false,"script":null)
]
}

[physics]

2d/physics_engine="GodotPhysics2D"
3d/physics_engine="Jolt Physics"
2d/sleep_threshold_linear=5.0
2d/sleep_threshold_angular=0.17453292519943295

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/vram_compression/import_etc2_astc=true
